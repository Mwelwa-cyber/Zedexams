{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "syllabi/*.pdf"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "/studio/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/syllabi/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" },
          { "key": "Content-Disposition", "value": "inline" }
        ]
      }
    ],
    "redirects": [
      { "source": "/welcome", "destination": "/", "type": 301 },
      { "source": "/plans", "destination": "/pricing", "type": 301 }
    ],
    "rewrites": [
      {
        "source": "/api/ai/chat",
        "function": {
          "functionId": "apiAiChat",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/teacher/lesson-plan/stream",
        "function": {
          "functionId": "apiGenerateLessonPlan",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/teacher/worksheet/stream",
        "function": {
          "functionId": "apiGenerateWorksheet",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/tts",
        "function": {
          "functionId": "apiTextToSpeech",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/payments/momo/initiate",
        "function": {
          "functionId": "apiCreateMomoPayment",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/payments/momo/status",
        "function": {
          "functionId": "apiMomoPaymentStatus",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "storage": {
      "port": 9199
    },
    "singleProjectMode": false
  }
}
