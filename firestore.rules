rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function callerRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin() { return isAuthed() && callerRole() == 'admin'; }
    function isTeacherOrAbove() { return isAuthed() && (callerRole() == 'teacher' || callerRole() == 'admin'); }
    function incoming() { return request.resource.data; }
    function changedKeys() { return request.resource.data.diff(resource.data).affectedKeys(); }
    // Teachers cannot set isPublished:true or status:'published'
    function teacherNotPublishing() {
      return incoming().isPublished == false
        && incoming().get('status', 'draft') != 'published';
    }
    // ── content-field validators ─────────────────────────────
    // These are data-integrity backstops, NOT authorization checks.
    // They only constrain fields that are present in the incoming doc, so
    // older documents without newer fields continue to pass. They defend
    // against bad client code and tampered clients that bypass UI validation.
    function _validGrade(value) { return value is string && value in ['4', '5', '6', '7']; }
    function _validSubject(value) { return value is string && value.size() >= 1 && value.size() <= 80; }
    function _validContentStatus(value) { return value is string && value in ['draft', 'pending', 'published', 'rejected']; }
    function _validQuestionType(value) { return value is string && value in ['mcq', 'short_answer', 'diagram', 'fill', 'short', 'tf', 'numeric', 'hotspot']; }
    function _validQuestionSubtype(value) { return value == null || (value is string && value in ['vocab', 'spelling', 'punctuation', 'sentence_ordering']); }

    function validQuizFields() {
      return (!('title' in incoming()) || (incoming().title is string && incoming().title.size() >= 1 && incoming().title.size() <= 200))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200))
        && (!('duration' in incoming()) || (incoming().duration is int && incoming().duration >= 5 && incoming().duration <= 180))
        && (!('totalMarks' in incoming()) || (incoming().totalMarks is int && incoming().totalMarks >= 0 && incoming().totalMarks <= 10000))
        && (!('questionCount' in incoming()) || (incoming().questionCount is int && incoming().questionCount >= 0 && incoming().questionCount <= 1000))
        && (!('status' in incoming()) || _validContentStatus(incoming().status))
        && (!('isPublished' in incoming()) || incoming().isPublished is bool)
        // Optional Parts grouping (PRISCA mock-paper layout). Cap list size;
        // per-element shape is enforced by the Zod schema client-side.
        && (!('parts' in incoming()) || (incoming().parts is list && incoming().parts.size() <= 20));
    }

    // Defence-in-depth on rich-text fields. Limits mirror the Zod schema in
    // src/editor/schema/question.js. Legacy records without the JSON mirrors
    // stay valid because all the new checks are gated on field presence.
    function validQuestionFields() {
      return (!('type' in incoming()) || _validQuestionType(incoming().type))
        && (!('marks' in incoming()) || (incoming().marks is int && incoming().marks >= 1 && incoming().marks <= 10))
        && (!('options' in incoming()) || (incoming().options is list && incoming().options.size() <= 20))
        && (!('order' in incoming()) || (incoming().order is int && incoming().order >= 0 && incoming().order <= 10000))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200))
        // HTML rich-text fields: stay as strings, enforce size caps.
        && (!('text' in incoming()) || (incoming().text is string && incoming().text.size() <= 100000))
        && (!('explanation' in incoming()) || (incoming().explanation is string && incoming().explanation.size() <= 100000))
        && (!('sharedInstruction' in incoming()) || (incoming().sharedInstruction is string && incoming().sharedInstruction.size() <= 100000))
        && (!('passage' in incoming()) || (incoming().passage is string && incoming().passage.size() <= 200000))
        // Tiptap JSON mirrors: must be a map (Firestore object) or null.
        // A string here would mean someone is double-stringifying JSON — reject.
        && (!('textJSON' in incoming()) || incoming().textJSON == null || incoming().textJSON is map)
        && (!('explanationJSON' in incoming()) || incoming().explanationJSON == null || incoming().explanationJSON is map)
        && (!('sharedInstructionJSON' in incoming()) || incoming().sharedInstructionJSON == null || incoming().sharedInstructionJSON is map)
        && (!('passageJSON' in incoming()) || incoming().passageJSON == null || incoming().passageJSON is map)
        // Content-version marker: may be absent (legacy) or an int in {1,2,3}.
        && (!('contentVersion' in incoming()) || (incoming().contentVersion is int && incoming().contentVersion >= 1 && incoming().contentVersion <= 3))
        // Diagram / image metadata.
        && (!('diagramText' in incoming()) || incoming().diagramText == null || (incoming().diagramText is string && incoming().diagramText.size() <= 2000))
        && (!('imageUrl' in incoming()) || incoming().imageUrl == null || (incoming().imageUrl is string && incoming().imageUrl.size() <= 2000))
        // Where the question image sits ('above' | 'below' | 'left' | 'right' | 'inline').
        // Null/absent on legacy docs → renderer falls back to 'above'.
        && (!('imagePosition' in incoming()) || incoming().imagePosition == null || (incoming().imagePosition is string && incoming().imagePosition.size() <= 16))
        // Library-diagram reference for the question image slot. Per-element
        // shape ({ libraryKey, params }) is enforced by the Zod schema
        // client-side, same convention used by `parts` and `optionMedia`.
        && (!('imageDiagram' in incoming()) || incoming().imageDiagram == null || incoming().imageDiagram is map)
        // Parallel media array aligned with options[i]. Per-element shape
        // ({ imageUrl?, diagram?, alt }) is enforced by the Zod schema
        // client-side, same convention used by `parts` above.
        && (!('optionMedia' in incoming()) || (incoming().optionMedia is list && incoming().optionMedia.size() <= 20))
        // Review flags (written by the AI importer).
        && (!('requiresReview' in incoming()) || incoming().requiresReview is bool)
        && (!('reviewNotes' in incoming()) || (incoming().reviewNotes is list && incoming().reviewNotes.size() <= 50))
        && (!('importWarnings' in incoming()) || (incoming().importWarnings is list && incoming().importWarnings.size() <= 50))
        // PRISCA mock-paper format: optional MCQ subtype + Part membership.
        && (!('subtype' in incoming()) || _validQuestionSubtype(incoming().subtype))
        && (!('partId' in incoming()) || incoming().partId == null || (incoming().partId is string && incoming().partId.size() <= 64))
        // Numeric-answer questions (#398): tolerance is an absolute slack
        // around correctAnswer. The Zod schema caps it at 1,000,000 and
        // requires ≥0; mirror those bounds here as a server-side backstop.
        // Null is allowed because every non-numeric question stores
        // `tolerance: null` (see normalizeQuestionPayload).
        && (!('tolerance' in incoming()) || incoming().tolerance == null || (incoming().tolerance is number && incoming().tolerance >= 0 && incoming().tolerance <= 1000000))
        // Hotspot-answer questions (#399): correctRegion is a normalised
        // { x, y, radius } target on the question's image. Per-key bounds
        // ([0,1] for x/y, [0,0.5] for radius) match src/editor/schema/question.js
        // and src/utils/hotspotGrading.js — keeps the rule from accepting
        // a region that the grader would reject as out-of-range.
        && (!('correctRegion' in incoming()) || incoming().correctRegion == null || (
              incoming().correctRegion is map
              && incoming().correctRegion.x is number
              && incoming().correctRegion.x >= 0 && incoming().correctRegion.x <= 1
              && incoming().correctRegion.y is number
              && incoming().correctRegion.y >= 0 && incoming().correctRegion.y <= 1
              && incoming().correctRegion.radius is number
              && incoming().correctRegion.radius >= 0 && incoming().correctRegion.radius <= 0.5
            ));
    }

    function validLessonFields() {
      return (!('title' in incoming()) || (incoming().title is string && incoming().title.size() >= 1 && incoming().title.size() <= 200))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200))
        && (!('status' in incoming()) || _validContentStatus(incoming().status))
        && (!('isPublished' in incoming()) || incoming().isPublished is bool)
        // Notes Studio fields. Optional/gate-on-presence so legacy
        // slide-built lessons remain valid. The file* and term/week fields
        // are explicitly allowed to be null because the editor writes them
        // as null whenever the note is in rich-text mode (or when the
        // teacher hasn't picked a term/week yet) — matching the same
        // null-or-string pattern used for question imageUrl/diagramText.
        && (!('noteFormat' in incoming()) || (incoming().noteFormat is string && incoming().noteFormat in ['slides', 'rich_text', 'file']))
        && (!('content' in incoming()) || (incoming().content is string && incoming().content.size() <= 200000))
        && (!('excerpt' in incoming()) || (incoming().excerpt is string && incoming().excerpt.size() <= 500))
        && (!('fileUrl' in incoming()) || incoming().fileUrl == null || (incoming().fileUrl is string && incoming().fileUrl.size() <= 2000))
        && (!('fileName' in incoming()) || incoming().fileName == null || (incoming().fileName is string && incoming().fileName.size() <= 200))
        && (!('storagePath' in incoming()) || incoming().storagePath == null || (incoming().storagePath is string && incoming().storagePath.size() <= 500))
        && (!('fileSize' in incoming()) || incoming().fileSize == null || (incoming().fileSize is int && incoming().fileSize >= 0 && incoming().fileSize <= 26214400))
        && (!('term' in incoming()) || incoming().term == null || (incoming().term is string && incoming().term.size() <= 20))
        && (!('week' in incoming()) || incoming().week == null || (incoming().week is string && incoming().week.size() <= 20));
    }

    function validResultFields() {
      return (!('score' in incoming()) || (incoming().score is number && incoming().score >= 0))
        && (!('percentage' in incoming()) || (incoming().percentage is number && incoming().percentage >= 0 && incoming().percentage <= 100))
        && (!('totalMarks' in incoming()) || (incoming().totalMarks is int && incoming().totalMarks >= 0 && incoming().totalMarks <= 10000))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject));
    }

    // ── users ─────────────────────────────────────────────────
    match /users/{userId} {
      // Self + admin only. The earlier `|| isTeacherOrAbove()` clause let
      // any teacher read any other user's profile, including subscription
      // phone numbers, payment IDs, and plan/billing fields.
      allow read: if isAuthed() && (isOwner(userId) || isAdmin());
      allow create: if isAuthed() && isOwner(userId)
        && incoming().role in ['learner', 'teacher']
        && incoming().get('plan', 'free') == 'free'
        && incoming().get('premium', false) == false
        && incoming().isPremium == false
        && incoming().get('paymentStatus', 'inactive') == 'inactive'
        && incoming().get('subscriptionStatus', 'inactive') == 'inactive'
        && incoming().get('subscriptionPlan', 'free') == 'free'
        && incoming().get('subscriptionExpiry', null) == null
        && incoming().get('subscriptionActivatedBy', null) == null
        && incoming().get('subscriptionActivatedAt', null) == null
        && incoming().get('premiumActivatedAt', null) == null
        && incoming().get('subscriptionProvider', null) == null
        && incoming().get('subscriptionPaymentId', null) == null
        && incoming().get('subscriptionPhoneNumber', null) == null;
      // Self-update: cannot change role or subscription fields. The
      // cancelAtPeriodEnd flag is in this list too (audit D4) — only
      // the setSubscriptionCancellation Cloud Function (admin SDK) is
      // allowed to toggle it, so a tampered client can't grant itself
      // a cancellation that wasn't logged in subscriptionEvents.
      //
      // Audit C7 — referralCode + referredBy are also blocklisted:
      // referralCode is once-write at create-time (immutable thereafter),
      // referredBy is captured from ?ref=… at signup and must never be
      // re-attributed to a different referrer. referralCount and
      // referralCredits are server-incremented by the future redemption
      // Cloud Function, so they're blocked from self-mutation too.
      allow update: if isAuthed() && isOwner(userId)
        && !changedKeys().hasAny([
          'role', 'plan', 'premium', 'isPremium', 'paymentStatus', 'subscriptionStatus',
          'premiumActivatedAt', 'subscriptionPlan', 'subscriptionExpiry', 'subscriptionActivatedBy',
          'subscriptionActivatedAt', 'subscriptionProvider', 'subscriptionPaymentId',
          'subscriptionPhoneNumber',
          'learnerPortalActive', 'learnerPortalPlan', 'learnerPortalProvider',
          'learnerPortalPhoneNumber', 'learnerPortalPaymentId',
          'learnerPortalActivatedAt', 'learnerPortalExpiry',
          'cancelAtPeriodEnd', 'cancelAtPeriodEndUpdatedAt', 'cancelAtPeriodEndReason',
          'referralCode', 'referredBy', 'referralCount', 'referralCredits',
          'referralCreditRedeemed'
        ]);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── exam_attempts (daily exam sessions) ──────────────────────
    // Submitted attempts are readable by all signed-in users (powers leaderboard).
    // In-progress attempts are private to the owner + admin.
    match /exam_attempts/{attemptId} {
      allow read:   if isAuthed() && (
        resource.data.status == 'submitted'
        || resource.data.userId == request.auth.uid
        || isAdmin()
      );
      allow create: if isAuthed() && incoming().userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── daily_exam_locks (one per user per subject per day) ───────
    match /daily_exam_locks/{lockId} {
      allow read:   if isAuthed() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthed() && incoming().userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── assessments (teacher-private) ─────────────────────────
    // Assessments are exam-style papers a teacher creates for their own
    // class. Unlike quizzes, they are NEVER shown to learners through the
    // app — teachers print/download them. So reads, writes, and deletes are
    // restricted to the owner. Admins can also read for support.
    function _validAssessmentType(value) {
      return value is string && value in [
        'weekly', 'monthly', 'mid_term', 'end_of_term', 'topic',
        'mock', 'diagnostic', 'pre_test', 'post_test', 'revision',
        'continuous', 'summative', 'practical', 'oral', 'project'
      ];
    }
    function validAssessmentFields() {
      return (!('title' in incoming()) || (incoming().title is string && incoming().title.size() >= 1 && incoming().title.size() <= 200))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200))
        && (!('assessmentType' in incoming()) || _validAssessmentType(incoming().assessmentType))
        && (!('duration' in incoming()) || (incoming().duration is int && incoming().duration >= 5 && incoming().duration <= 600))
        && (!('totalMarks' in incoming()) || (incoming().totalMarks is int && incoming().totalMarks >= 0 && incoming().totalMarks <= 10000))
        && (!('questionCount' in incoming()) || (incoming().questionCount is int && incoming().questionCount >= 0 && incoming().questionCount <= 1000))
        && (!('schoolName' in incoming()) || (incoming().schoolName is string && incoming().schoolName.size() <= 200))
        && (!('className' in incoming()) || (incoming().className is string && incoming().className.size() <= 100))
        && (!('term' in incoming()) || (incoming().term is string && incoming().term.size() <= 20))
        && (!('assessmentDate' in incoming()) || (incoming().assessmentDate is string && incoming().assessmentDate.size() <= 40))
        && (!('coverInstructions' in incoming()) || (incoming().coverInstructions is string && incoming().coverInstructions.size() <= 4000))
        && (!('parts' in incoming()) || (incoming().parts is list && incoming().parts.size() <= 20))
        // Library coords ({ libraryType, syllabus, gradeForm, term, subject,
        // assessmentType, path }) populated by AssessmentStudio so the saved
        // doc lands in the canonical /Assessments/<syllabus>/<grade>/<term>/
        // <subject>/<assessmentType>/ folder. All optional, all strings.
        && (!('library' in incoming()) || (incoming().library is map && incoming().library.size() <= 16));
    }
    match /assessments/{assessmentId} {
      allow read: if isAuthed() && (
        isAdmin() || resource.data.createdBy == request.auth.uid
      );
      allow create: if validAssessmentFields()
        && isTeacherOrAbove()
        && incoming().createdBy == request.auth.uid;
      allow update: if validAssessmentFields()
        && isTeacherOrAbove()
        && resource.data.createdBy == request.auth.uid
        && incoming().createdBy == request.auth.uid;
      allow delete: if isAuthed() && (
        isAdmin() || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid)
      );

      match /questions/{questionId} {
        allow read: if isAuthed() && (
          isAdmin()
          || get(/databases/$(database)/documents/assessments/$(assessmentId)).data.createdBy == request.auth.uid
        );
        allow create, update: if validQuestionFields() && isTeacherOrAbove()
          && get(/databases/$(database)/documents/assessments/$(assessmentId)).data.createdBy == request.auth.uid;
        allow delete: if isAuthed() && (
          isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/assessments/$(assessmentId)).data.createdBy == request.auth.uid)
        );
      }
    }

    // ── quizzes ───────────────────────────────────────────────
    match /quizzes/{quizId} {
      // Anyone signed in can read published quizzes and daily exams; the
      // creating teacher can read their own drafts. Admins read everything
      // for support. Earlier `|| isTeacherOrAbove()` clause let any
      // teacher read every other teacher's unpublished drafts.
      allow read: if isAuthed() && (
        resource.data.isPublished == true
        || resource.data.get('quizType', '') == 'daily_exam'
        || resource.data.createdBy == request.auth.uid
        || isAdmin()
      );
      // Admin: create anything. Teacher: only draft/pending (cannot publish directly)
      allow create: if validQuizFields() && (
        (isAdmin() && incoming().createdBy == request.auth.uid)
        || (isTeacherOrAbove() && incoming().createdBy == request.auth.uid && teacherNotPublishing())
      );
      // Admin: update anything. Teacher: only own non-published content, cannot publish.
      allow update: if validQuizFields() && (
        isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false && teacherNotPublishing())
      );
      // Admin can delete anything; teachers can only delete their own unpublished content
      allow delete: if isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false);

      match /questions/{questionId} {
        // Mirror the parent quiz read rule. The earlier `if isAuthed()` let
        // every signed-in user (incl. learners) read every teacher's draft
        // questions, including answer keys and explanations.
        allow read: if isAuthed() && (
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.isPublished == true
          || get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('quizType', '') == 'daily_exam'
          || get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid
          || isAdmin()
        );
        allow create, update: if validQuestionFields() && (
          isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid)
        );
        allow delete: if isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid);
      }
    }

    // ── results ───────────────────────────────────────────────
    match /results/{resultId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
        || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(resource.data.quizId)).data.createdBy == request.auth.uid)
      );
      allow create: if isAuthed() && incoming().userId == request.auth.uid && validResultFields();
      allow update: if isAuthed() && resource.data.userId == request.auth.uid && validResultFields();
      allow delete: if isAdmin();
    }

    // ── lessons ───────────────────────────────────────────────
    match /lessons/{lessonId} {
      // Learners can only read published; teachers can read their own or any (if teacher+); admin reads all
      allow read: if isAuthed() && (
        resource.data.isPublished == true || isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid)
      );
      // Admin: create anything. Teacher: only draft/pending.
      allow create: if validLessonFields() && (
        (isAdmin() && incoming().createdBy == request.auth.uid)
        || (isTeacherOrAbove() && incoming().createdBy == request.auth.uid && teacherNotPublishing())
      );
      // Admin: update anything. Teacher: own non-published content only, cannot publish.
      allow update: if validLessonFields() && (
        isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false && teacherNotPublishing())
      );
      allow delete: if isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false);
    }

    // ── payments ──────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthed() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── aiGenerations (teacher tools) ─────────────────────────
    match /aiGenerations/{genId} {
      allow read:   if isAuthed() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      // Client never creates these — only the Cloud Function does (admin SDK bypasses rules).
      allow create: if false;
      // Teachers can update their own generations' output (in-place editing),
      // the teacherEdited / visibility / exportedFormats metadata fields, and
      // the `library` map (canonical Schemes/Forecasts/Lesson Plans/Notes/
      // Assessments classification — see src/config/library.js).
      // Structural fields (tool, ownerUid, inputs, tokens, etc.) remain
      // immutable from the client.
      allow update: if isAuthed()
                       && resource.data.ownerUid == request.auth.uid
                       && changedKeys().hasOnly([
                         'output', 'teacherEdited', 'visibility', 'exportedFormats',
                         'library',
                       ])
                       && incoming().ownerUid == resource.data.ownerUid
                       && incoming().tool == resource.data.tool;
      // Admin can update anything (for moderation, flag/unflag etc.)
      allow update: if isAdmin();
      allow delete: if isAuthed() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── agentJobs (AI agent operating model) ──────────────────
    // Single bus for all agent work. Clients can create jobs (teacher
    // briefs) and read their own; admins can read all and approve/reject.
    // Output and status transitions are written by Cloud Functions only.
    match /agentJobs/{jobId} {
      allow read: if isAuthed() && (resource.data.createdBy == request.auth.uid || isAdmin());

      // Clients create a job by setting agentId, department, input only.
      // Status is forced to 'queued'; output, error, reviewedBy stay
      // empty until the dispatcher / admin acts. Restricted to teachers
      // and admins because the dispatcher invokes server-side runners
      // (e.g. runLessonPlan) that are paid teacher tools.
      allow create: if isTeacherOrAbove()
                       && incoming().agentId is string
                       && incoming().agentId.size() <= 64
                       && incoming().department is string
                       && incoming().department.size() <= 32
                       && incoming().status == 'queued'
                       && incoming().createdBy == request.auth.uid
                       && (!('output' in incoming()))
                       && (!('error' in incoming()))
                       && (!('reviewedBy' in incoming()))
                       && (!('publishedRefs' in incoming()));

      // Admin updates: only the review fields. Output / status transitions
      // beyond approve/reject come from the Cloud Function (admin SDK).
      allow update: if isAdmin()
                       && changedKeys().hasOnly(['status', 'reviewedBy', 'reviewedAt', 'reviewNotes'])
                       && (incoming().status == 'approved'
                           || incoming().status == 'rejected'
                           || incoming().status == resource.data.status);

      allow delete: if isAdmin();
    }

    // ── agentControl (per-agent circuit breaker) ──────────────
    // Admins toggle paused:true to halt an agent; the dispatcher checks
    // this before enqueueing or running.
    match /agentControl/{agentId} {
      allow read:   if isAuthed();
      allow write:  if isAdmin();
    }

    // ── teacherLibraries ──────────────────────────────────────
    match /teacherLibraries/{uid} {
      allow read: if isAuthed() && (isOwner(uid) || isAdmin());
      match /items/{itemId} {
        allow read, write, delete: if isAuthed() && isOwner(uid);
      }
      match /folders/{folderId} {
        allow read, write, delete: if isAuthed() && isOwner(uid);
      }
    }

    // ── usageMeters ───────────────────────────────────────────
    match /usageMeters/{uid} {
      allow read: if isAuthed() && (isOwner(uid) || isAdmin());
      match /periods/{periodId} {
        allow read:  if isAuthed() && (isOwner(uid) || isAdmin());
        allow write: if false;  // Cloud Functions only (admin SDK).
      }
    }

    // ── private CBC curriculum grounding ─────────────────────
    // These collections hold the raw server-side curriculum corpus used to
    // ground AI generations. They must never be exposed to the browser.
    match /curriculum/{docId} {
      allow read, write: if false;
    }
    match /rag_chunks/{docId} {
      allow read, write: if false;
    }

    // ── cbcKnowledgeBase ──────────────────────────────────────
    match /cbcKnowledgeBase/{version} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
      match /topics/{topicId} {
        allow read:  if isAuthed();
        allow write: if isAdmin();
      }
    }

    // ── promptTemplates ───────────────────────────────────────
    // Admin-only. Never exposed to non-admin clients.
    match /promptTemplates/{toolId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // ── schoolLicences ────────────────────────────────────────
    match /schoolLicences/{licenceId} {
      allow read:  if isAuthed() && (request.auth.uid in resource.data.memberUids || isAdmin());
      allow write: if isAdmin();
    }

    // ── games (public read, admin write) ──────────────────────
    // Students play games anonymously. Admins curate/seed content.
    // Document shape:
    //   { title, subject, grade, type, difficulty, description, timer,
    //     points, active, cbc_topic, questions[], generator?,
    //     createdAt, updatedAt, createdBy }
    match /games/{gameId} {
      allow read:   if resource.data.get('active', true) == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── scores (student-submitted play results) ───────────────
    // Read: public (powers leaderboards — only name + score leak out).
    // Create: signed-in players only; can only write their own userId.
    // Update/delete: admin only (prevents tampering with leaderboards).
    match /scores/{scoreId} {
      allow read:   if true;
      allow create: if isAuthed()
        && incoming().userId == request.auth.uid
        && incoming().gameId is string
        && incoming().score is number
        && incoming().grade is number
        && incoming().subject is string
        && incoming().playedAt == request.time;
      allow update, delete: if isAdmin();
    }

    // ── leaderboards (aggregated top-N per game; Cloud Function writes) ─
    match /leaderboards/{gameId} {
      allow read:  if true;
      allow write: if isAdmin();  // Cloud Functions also bypass via admin SDK
    }

    // ── badges (per-user earned badges) ───────────────────────
    // Self-awarded game badges are OK — the client evaluates against the
    // score just saved to `scores`. Tampering is low-stakes (the leaderboard
    // still uses real scores, badges are decorative). Admin moderates.
    match /badges/{userId} {
      allow read:          if isAuthed() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthed() && isOwner(userId);
      allow delete:        if isAdmin();
    }

    // ── daily_challenges (one featured game per day) ──────────
    // Docs are keyed by ISO date (YYYY-MM-DD). Empty collection is fine
    // — the client falls back to a deterministic rotation when no doc exists.
    match /daily_challenges/{dateId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── dailyStreaks (per-user streak counter for the daily challenge) ──
    // Single doc per user: { streak, longestStreak, lastPlayedDate, lastGameId }
    match /dailyStreaks/{userId} {
      allow read:          if isAuthed() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthed() && isOwner(userId);
      allow delete:        if isAdmin();
    }

    // ── learner_profiles (per-user learning intelligence snapshot) ──
    // Single doc per user holding totals, per-subject stats, per-topic
    // stats, weak topics, recent games, last session, and today's goal.
    // Owner-only read/write — this is a derived personal record, not
    // leaderboard data. Admin may moderate/delete.
    match /learner_profiles/{userId} {
      allow read:          if isAuthed() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthed() && isOwner(userId);
      allow delete:        if isAdmin();
    }

    // ── shares (public read-only snapshots of teacher generations) ─
    // Teachers publish a plan to the web via a share button. The doc is
    // keyed by a random token (doc ID = token) and contains a snapshot
    // of the plan at share-time (so later edits don't change what the
    // share URL shows). The token IS the share URL — knowing it is
    // permission to read. Anyone with the link can view; only the
    // owner (or admin) can update or unpublish.
    //
    // Document shape:
    //   { tool, ownerUid, title, plan, subject, grade, topic, createdAt, revokedAt? }
    match /shares/{token} {
      // Always readable — the token IS the permission. Client checks
      // `revokedAt` and shows the appropriate "revoked" / "not found"
      // state instead of the read failing with permission-denied.
      allow read: if true;
      allow create: if isAuthed()
        && incoming().ownerUid == request.auth.uid
        && incoming().keys().hasAll(['tool', 'ownerUid', 'title', 'plan', 'createdAt'])
        && incoming().tool is string
        && incoming().tool.size() <= 40
        && incoming().title is string
        && incoming().title.size() <= 200
        && incoming().plan is map
        && incoming().createdAt == request.time;
      allow update: if isAuthed()
        && resource.data.ownerUid == request.auth.uid
        && changedKeys().hasOnly(['revokedAt', 'title']);
      allow update: if isAdmin();
      allow delete: if isAuthed() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // Saved generated content — what teachers explicitly "Save" from a
    // chat. Documents inherit the chat / message they came from but live
    // in their own collection so they can be searched, edited, and turned
    // into other artifacts (tests, schemes, etc.) independently.
    match /generatedContent/{contentId} {
      // Saved generated content is private to its owner. Admins retain
      // read access for support. (Earlier `|| isTeacherOrAbove()` clause
      // leaked every teacher's saved AI content to every other teacher.)
      allow read: if isAuthed()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
      allow create: if isAuthed()
        && incoming().ownerUid == request.auth.uid
        && incoming().keys().hasAll(['ownerUid', 'contentType', 'content', 'createdAt'])
        && incoming().contentType is string && incoming().contentType.size() <= 40
        && incoming().content is string && incoming().content.size() <= 200000;
      allow update: if isAuthed()
        && resource.data.ownerUid == request.auth.uid
        && changedKeys().hasOnly([
            'content', 'title', 'subject', 'grade', 'topic', 'tags',
            'starred', 'archived', 'updatedAt',
          ]);
      allow delete: if isAuthed()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // Learner progress — written by future learner tools (and by teachers
    // when they record offline observations). Read by the owning learner,
    // by a teacher of that learner's class, and by admins.
    match /learnerProgress/{progressId} {
      // Read by the owning learner, by the teacher recorded on the doc, or
      // by an admin. The previous `|| isTeacherOrAbove()` clause let any
      // teacher read every learner's progress regardless of class
      // membership; teachers get access only via `teacherUid` ownership.
      allow read: if isAuthed()
        && (resource.data.learnerUid == request.auth.uid
            || resource.data.teacherUid == request.auth.uid
            || isAdmin());
      // Create is restricted to the learner writing their own progress
      // record. Teacher-side observations should flow through a Cloud
      // Function so the teacher↔learner relationship can be verified
      // server-side; allowing teacherUid==self at the rule layer let any
      // signed-in user fabricate "teacher observation" records about
      // arbitrary learners.
      allow create: if isAuthed()
        && incoming().learnerUid == request.auth.uid
        && incoming().keys().hasAll(['learnerUid', 'createdAt'])
        // Pin createdAt to the server clock so clients can't backdate or
        // post-date observation records (skews analytics + ordering).
        // Mirrors the pattern used by /shares and /generatedContent.
        && incoming().createdAt == request.time
        && incoming().learnerUid is string && incoming().learnerUid.size() <= 64
        && (!('subject' in incoming()) || (incoming().subject is string && incoming().subject.size() <= 80))
        && (!('topic'   in incoming()) || (incoming().topic   is string && incoming().topic.size() <= 200))
        && (!('weakAreas' in incoming()) || incoming().weakAreas is list)
        && (!('score'   in incoming()) || (incoming().score is number && incoming().score >= 0 && incoming().score <= 100));
      allow update: if isAuthed()
        && (resource.data.learnerUid == request.auth.uid
            || resource.data.teacherUid == request.auth.uid
            || isAdmin());
      allow delete: if isAdmin();
    }

    // ── progressShares (audit A3 — parent portal + weekly digest) ─────
    //
    // A learner issues a "share my progress with my parent" link from
    // their profile. The doc is keyed by a random token and the token
    // IS the permission to read — same pattern as /shares above.
    //
    // Schema:
    //   learnerUid (the child), createdBy (always the learner uid),
    //   parentEmail?, parentPhone?, parentDisplayName?,
    //   createdAt, expiresAt, revokedAt?,
    //   lastViewedAt?, viewCount? (server-bumped via Cloud Function)
    //
    // We expose only the metadata via direct Firestore read; the
    // actual rendered summary (recent scores, weak subjects, streak)
    // comes from getProgressShare (Cloud Function), which uses
    // admin SDK to bypass results read rules.
    function validProgressShareFields() {
      return (!('learnerUid' in incoming()) || (incoming().learnerUid is string && incoming().learnerUid.size() <= 100))
        && (!('createdBy' in incoming()) || (incoming().createdBy is string && incoming().createdBy.size() <= 100))
        && (!('parentEmail' in incoming()) || incoming().parentEmail == null || (incoming().parentEmail is string && incoming().parentEmail.size() <= 200))
        && (!('parentPhone' in incoming()) || incoming().parentPhone == null || (incoming().parentPhone is string && incoming().parentPhone.size() <= 30))
        && (!('parentDisplayName' in incoming()) || incoming().parentDisplayName == null || (incoming().parentDisplayName is string && incoming().parentDisplayName.size() <= 80))
        && (!('expiresAt' in incoming()) || incoming().expiresAt is timestamp);
    }
    // ── appCheckHealth (audit B3 — soft-verify observability) ─────────
    // Per-day rollups of App Check verification attempts. Schema:
    //   appCheckHealth/{YYYY-MM-DD}: {
    //     date,
    //     {label}_attempts, {label}_valid,
    //     {label}_missing, {label}_invalid,
    //     updatedAt
    //   }
    // Admin-read only — leaks per-day attestation telemetry that
    // shouldn't be surfaced to users. Server-only writes.
    match /appCheckHealth/{date} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── invoices (audit D3 — MoMo receipts / accounting) ──────────────
    // Server-issued receipts for successful payments. Schema:
    //   paymentId, userId, number ('ZE-YYYYMMDD-XXXXXX'),
    //   planId, planName, amount, currency,
    //   provider, phoneNumber, storagePath ('invoices/{uid}/{paymentId}.pdf'),
    //   emailedTo?, emailedAt?, issuedAt
    // The doc is keyed by paymentId so the success-path retry guard
    // ("if the invoice already exists, don't double-emit") is a single
    // get(). Read access is the owning learner + admin; writes are
    // server-only via the invoiceGenerator module (admin SDK bypass).
    match /invoices/{invoiceId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create, update, delete: if false;
    }

    // ── aiUsage (audit B4 — Claude API cost tracking) ─────────────────
    // Daily rollups written exclusively by aiCostTracking.recordAiUsage
    // (Cloud Functions, admin SDK). Admin-only reads — the data
    // exposes per-user spend which is sensitive operational info.
    // Schema:
    //   aiUsage/{date} { totalCostUsd, callCount, totalInput/Output... }
    //   aiUsage/{date}/users/{uid} { costUsd, callCount, ... }
    //   aiUsage/{date}/tools/{tool} { costUsd, callCount, ... }
    match /aiUsage/{date} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
      match /{subColl}/{docId} {
        allow read: if isAdmin();
        allow create, update, delete: if false;
      }
    }

    // ── parentDigestEvents (audit A3 PR 2 — weekly digest audit log) ──
    // Append-only ledger written exclusively by the weekly digest
    // cron (admin SDK). The owning learner can read their own rows
    // to verify a digest went out; admins can read everything.
    match /parentDigestEvents/{eventId} {
      allow read: if isAuthed() && (resource.data.learnerUid == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /progressShares/{token} {
      // Token IS the permission — anyone with the link can read.
      // Client + Cloud Function check revokedAt / expiresAt and show
      // the "revoked" / "expired" state rather than 404.
      allow read: if true;
      allow create: if isAuthed()
        && validProgressShareFields()
        && incoming().learnerUid == request.auth.uid
        && incoming().createdBy == request.auth.uid;
      allow update: if isAuthed()
        && validProgressShareFields()
        && resource.data.learnerUid == request.auth.uid
        && incoming().learnerUid == resource.data.learnerUid;
      allow delete: if isAuthed() && (
        resource.data.learnerUid == request.auth.uid || isAdmin()
      );
    }

    // ── assignments (audit A10 PR 3 — teacher assigns work to a class) ──
    //
    // Each doc points one resource (quiz or daily exam) at one class.
    // Schema:
    //   classId, teacherUid (denormalised owner uid),
    //   resourceType ('quiz'|'exam'), resourceId,
    //   resourceTitle, subject, grade (denormalised display fields),
    //   dueAt? (timestamp), assignedAt, active
    //
    // Read access intentionally wide-open to signed-in users — the
    // payload is just a pointer at content already gated by its own
    // collection's rules. Writes are routed through Cloud Functions
    // (createClassAssignment / deleteClassAssignment) so a tampered
    // client can't mint an assignment for a class they don't own.
    function _validResourceType(value) { return value is string && value in ['quiz', 'exam']; }
    function validAssignmentFields() {
      return (!('classId' in incoming()) || (incoming().classId is string && incoming().classId.size() <= 100))
        && (!('teacherUid' in incoming()) || (incoming().teacherUid is string && incoming().teacherUid.size() <= 100))
        && (!('resourceType' in incoming()) || _validResourceType(incoming().resourceType))
        && (!('resourceId' in incoming()) || (incoming().resourceId is string && incoming().resourceId.size() <= 100))
        && (!('resourceTitle' in incoming()) || (incoming().resourceTitle is string && incoming().resourceTitle.size() <= 200))
        && (!('subject' in incoming()) || incoming().subject == null || _validSubject(incoming().subject))
        && (!('grade' in incoming()) || incoming().grade == null || (incoming().grade is string && incoming().grade.size() <= 5))
        && (!('dueAt' in incoming()) || incoming().dueAt == null || incoming().dueAt is timestamp)
        && (!('active' in incoming()) || incoming().active is bool);
    }
    match /assignments/{assignmentId} {
      allow read: if isAuthed();
      allow create: if isTeacherOrAbove()
        && validAssignmentFields()
        && incoming().teacherUid == request.auth.uid;
      allow update: if isAuthed()
        && validAssignmentFields()
        && resource.data.teacherUid == request.auth.uid;
      allow delete: if isAuthed() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
    }

    // ── classes + classInvites (audit A10 — teacher classroom roster) ──
    //
    // A class is a teacher-owned roster of learners. Schema:
    //   name, description (optional), grade ('4'|'5'|'6'|'7'),
    //   subject (optional slug — class can span subjects),
    //   teacherUid (owner), school (optional),
    //   inviteCode (denormalised — the live code, also keyed in
    //                classInvites/{code} for fast lookup),
    //   learners: array<uid> (max 200 per class — approved roster),
    //   pendingLearners: array<uid> (awaiting teacher approval, max 200),
    //   active: bool, createdAt, updatedAt
    //
    // Read access widens to any class member (approved or pending) so a
    // learner can see the roster + class info for classes they belong
    // to, and a pending learner can see the "awaiting approval" state.
    // Other learners see nothing — privacy-first; classmate emails /
    // uids must not leak across schools.
    //
    // Write access is the teacher owner OR a Cloud Function (admin
    // SDK bypasses these rules). The "join-by-code" + approve / decline
    // flows go through callables (joinClassByCode / approveLearner /
    // declineLearner) so a learner can never directly mutate someone
    // else's class doc — that's the security promise.
    function _validClassGrade(value) { return value is string && value in ['4', '5', '6', '7']; }
    function validClassFields() {
      return (!('name' in incoming()) || (incoming().name is string && incoming().name.size() >= 1 && incoming().name.size() <= 200))
        && (!('description' in incoming()) || incoming().description == null || (incoming().description is string && incoming().description.size() <= 1000))
        && (!('grade' in incoming()) || _validClassGrade(incoming().grade))
        && (!('subject' in incoming()) || incoming().subject == null || _validSubject(incoming().subject))
        && (!('school' in incoming()) || incoming().school == null || (incoming().school is string && incoming().school.size() <= 200))
        && (!('inviteCode' in incoming()) || (incoming().inviteCode is string && incoming().inviteCode.size() >= 6 && incoming().inviteCode.size() <= 16))
        && (!('learners' in incoming()) || (incoming().learners is list && incoming().learners.size() <= 200))
        && (!('pendingLearners' in incoming()) || (incoming().pendingLearners is list && incoming().pendingLearners.size() <= 200))
        && (!('active' in incoming()) || incoming().active is bool);
    }
    match /classes/{classId} {
      allow read: if isAuthed() && (
        resource.data.teacherUid == request.auth.uid
        || (resource.data.learners is list && request.auth.uid in resource.data.learners)
        || (resource.data.pendingLearners is list && request.auth.uid in resource.data.pendingLearners)
        || isAdmin()
      );
      allow create: if isTeacherOrAbove()
        && validClassFields()
        && incoming().teacherUid == request.auth.uid
        && incoming().get('learners', []) is list
        && incoming().get('learners', []).size() == 0
        && incoming().get('pendingLearners', []) is list
        && incoming().get('pendingLearners', []).size() == 0;
      allow update: if isAuthed()
        && resource.data.teacherUid == request.auth.uid
        && validClassFields()
        && incoming().teacherUid == resource.data.teacherUid;
      allow delete: if isAuthed() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
    }

    // Invite codes — keyed by the code string itself for O(1) lookup
    // when a learner joins. Public-readable so an anonymous-but-
    // signed-in learner can resolve a code → classId before the
    // joinClassByCode Cloud Function authenticates them in.
    match /classInvites/{inviteCode} {
      allow read: if isAuthed();
      allow create, update: if isTeacherOrAbove()
        && incoming().createdBy == request.auth.uid
        && incoming().classId is string
        && incoming().expiresAt is timestamp;
      allow delete: if isAuthed() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
    }

    // ── paperAttempts (audit A2 PR 3 — timed practice runs) ──────────
    //
    // A learner can practise any published past paper under a timer.
    // Each run records when they started, when they submitted, the
    // elapsed seconds, and an optional self-reflection note. We don't
    // auto-grade — past papers are PDFs and the mark scheme is the
    // teacher / parent step. The attempt is for the learner's own
    // tracking and the future "your second attempt was 12 minutes
    // faster" UX.
    //
    // Schema:
    //   paperAttempts/{attemptId} {
    //     userId, paperId, paperTitle, paperGrade, paperSubject,
    //     paperYear, durationMinutes (target), elapsedSeconds (actual),
    //     startedAt, submittedAt?, reflection? (string),
    //     status: 'in_progress' | 'submitted' | 'abandoned'
    //   }
    function _validAttemptStatus(value) { return value is string && value in ['in_progress', 'submitted', 'abandoned']; }
    function validPaperAttemptFields() {
      return (!('userId' in incoming()) || (incoming().userId is string && incoming().userId.size() <= 100))
        && (!('paperId' in incoming()) || (incoming().paperId is string && incoming().paperId.size() <= 100))
        && (!('paperTitle' in incoming()) || (incoming().paperTitle is string && incoming().paperTitle.size() <= 200))
        && (!('durationMinutes' in incoming()) || incoming().durationMinutes == null || (incoming().durationMinutes is int && incoming().durationMinutes >= 1 && incoming().durationMinutes <= 480))
        && (!('elapsedSeconds' in incoming()) || incoming().elapsedSeconds == null || (incoming().elapsedSeconds is int && incoming().elapsedSeconds >= 0 && incoming().elapsedSeconds <= 60 * 60 * 12))
        && (!('reflection' in incoming()) || incoming().reflection == null || (incoming().reflection is string && incoming().reflection.size() <= 1000))
        && (!('status' in incoming()) || _validAttemptStatus(incoming().status));
    }
    match /paperAttempts/{attemptId} {
      allow read: if isAuthed() && (resource.data.userId == request.auth.uid || isAdmin());
      // Owner-create only, with their own uid stamped on.
      allow create: if isAuthed()
        && validPaperAttemptFields()
        && incoming().userId == request.auth.uid;
      // Owner can update only the fields needed to mark complete.
      // The userId / paperId / startedAt are immutable once written.
      allow update: if isAuthed()
        && resource.data.userId == request.auth.uid
        && validPaperAttemptFields()
        && incoming().userId == resource.data.userId
        && incoming().paperId == resource.data.paperId;
      allow delete: if isAdmin();
    }

    // ── pastPapers (audit A2 — ECZ past-paper archive) ──────────────
    // Public read for published papers (the archive is a marketing /
    // SEO draw — anonymous visitors browse the list, sign in to
    // download/view the actual PDF). Drafts and archived papers are
    // admin-only. Writes admin-only too.
    //
    // Field shape (validated on write):
    //   title, grade ('7'|'9'|'12'), subject (slug), year (int),
    //   examBoard ('ECZ' default), paperNumber (int 1-3, optional),
    //   pdfPath (Storage path), pdfFilename, pdfSize (bytes),
    //   markSchemePath, markSchemeFilename (optional, separate PDF),
    //   description (optional), durationMinutes, totalMarks (optional),
    //   status ('draft'|'published'|'archived'),
    //   uploadedBy (uid), uploadedAt, updatedAt,
    //   views, downloads (server-incremented counters)
    function _validPaperGrade(value) { return value is string && value in ['7', '9', '12']; }
    function _validPaperStatus(value) { return value is string && value in ['draft', 'published', 'archived']; }
    function validPastPaperFields() {
      return (!('title' in incoming()) || (incoming().title is string && incoming().title.size() >= 1 && incoming().title.size() <= 200))
        && (!('grade' in incoming()) || _validPaperGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject))
        && (!('year' in incoming()) || (incoming().year is int && incoming().year >= 1990 && incoming().year <= 2100))
        && (!('paperNumber' in incoming()) || incoming().paperNumber == null || (incoming().paperNumber is int && incoming().paperNumber >= 1 && incoming().paperNumber <= 5))
        && (!('examBoard' in incoming()) || (incoming().examBoard is string && incoming().examBoard.size() <= 20))
        && (!('pdfPath' in incoming()) || (incoming().pdfPath is string && incoming().pdfPath.size() <= 500))
        && (!('pdfFilename' in incoming()) || (incoming().pdfFilename is string && incoming().pdfFilename.size() <= 200))
        && (!('pdfSize' in incoming()) || (incoming().pdfSize is int && incoming().pdfSize >= 0 && incoming().pdfSize <= 26214400))
        && (!('markSchemePath' in incoming()) || incoming().markSchemePath == null || (incoming().markSchemePath is string && incoming().markSchemePath.size() <= 500))
        && (!('markSchemeFilename' in incoming()) || incoming().markSchemeFilename == null || (incoming().markSchemeFilename is string && incoming().markSchemeFilename.size() <= 200))
        && (!('description' in incoming()) || incoming().description == null || (incoming().description is string && incoming().description.size() <= 1000))
        && (!('durationMinutes' in incoming()) || incoming().durationMinutes == null || (incoming().durationMinutes is int && incoming().durationMinutes >= 5 && incoming().durationMinutes <= 480))
        && (!('totalMarks' in incoming()) || incoming().totalMarks == null || (incoming().totalMarks is int && incoming().totalMarks >= 0 && incoming().totalMarks <= 1000))
        && (!('status' in incoming()) || _validPaperStatus(incoming().status));
    }
    match /pastPapers/{paperId} {
      // Anonymous-readable index: published papers list freely so
      // search engines can index them and signed-out visitors can
      // browse before sign-up. Drafts + archived are admin-only.
      allow read: if resource.data.get('status', 'draft') == 'published' || isAdmin();
      allow create: if isAdmin()
        && validPastPaperFields()
        && incoming().uploadedBy == request.auth.uid;
      allow update: if isAdmin() && validPastPaperFields();
      allow delete: if isAdmin();
    }

    // ── publicStats (audit C4 — marketing-page social proof) ──────────
    // One document (publicStats/global) refreshed every 30 minutes by
    // the updatePublicStats Cloud Function (admin SDK). Public-read so
    // the marketing surface can render learner / quiz / game counts to
    // anonymous visitors without auth. No client writes.
    match /publicStats/{docId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    // Public marketing contact form. Visitors are unauthenticated, so we
    // only allow create with strict shape + size validation. Reads,
    // updates, and deletes are admin-only (use the Firebase console).
    // ── subscriptionEvents (audit log for D4 self-serve cancel/reactivate) ──
    // Append-only ledger written exclusively by the
    // setSubscriptionCancellation Cloud Function (admin SDK). The
    // owning user can read their own row to verify the action took
    // effect; admins can read everything for support triage.
    match /subscriptionEvents/{eventId} {
      allow read: if isAuthed() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create, update, delete: if false;
    }

    match /contactMessages/{messageId} {
      allow read, update, delete: if isAdmin();
      allow create: if incoming().keys().hasOnly([
            'name', 'email', 'phone', 'role', 'message', 'source', 'createdAt'
          ])
        && incoming().keys().hasAll(['name', 'email', 'message', 'source', 'createdAt'])
        && incoming().name is string && incoming().name.size() > 0 && incoming().name.size() <= 100
        && incoming().email is string && incoming().email.size() > 0 && incoming().email.size() <= 200
        && incoming().message is string && incoming().message.size() > 0 && incoming().message.size() <= 2000
        && incoming().source is string && incoming().source.size() <= 60
        && incoming().createdAt == request.time
        && (!('phone' in incoming()) || (incoming().phone is string && incoming().phone.size() <= 30))
        && (!('role'  in incoming()) || (incoming().role  is string && incoming().role  in ['parent', 'teacher', 'school', 'learner', 'other']));
    }

    // ── newsletterSubscribers (audit C6 — list builder) ───────────────
    //
    // Writes are routed exclusively through the subscribeToNewsletter
    // Cloud Function so we can enforce email validation, dedupe, IP
    // rate limit, and a honeypot — none of which we can do from
    // Firestore rules. Direct client writes are blocked.
    //
    // Reads admin-only — the list is operationally sensitive (it's a
    // raw email list of people interested in a Zambian education
    // brand; misuse would burn future deliverability).
    match /newsletterSubscribers/{email} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── newsletterSignupRateLimit (per-IP daily counter) ──────────────
    // Internal counter the Cloud Function maintains. Not for client eyes.
    match /newsletterSignupRateLimit/{key} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    // ── referralCodes (audit C7 — code → uid lookup) ──────────────────
    //
    // The doc id IS the 8-char referral code. Each doc maps a code
    // to the uid of the user who owns it, enabling O(1) referrer
    // resolution at signup + at redemption time (PR 2).
    //
    // Read access is signed-in users so the future redeem-at-checkout
    // path can resolve a code → uid without going through a Cloud
    // Function. The lookup payload is just { uid, createdAt } — no
    // sensitive fields, and the uid is also exposed via the user's
    // own user doc.
    //
    // Create-only by the owner (a tampered client cannot mint a code
    // pointing at someone else's uid). Once-write — no updates ever,
    // so a referrer can never silently re-point their code.
    match /referralCodes/{code} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && incoming().keys().hasOnly(['uid', 'createdAt'])
        && incoming().uid == request.auth.uid
        && incoming().uid is string && incoming().uid.size() <= 100;
      allow update, delete: if false;
    }

    // ── referralRedemptions (audit C7 PR 2 — credit ledger) ───────────
    //
    // Server-only writes via the redeemReferralCredit helper (admin
    // SDK). Each doc captures one redemption event: who referred whom,
    // which payment triggered it, what the bonus was. /admin can read
    // everything for reconciliation; the referee + referrer can read
    // their own rows so a future ReferralActivity panel could surface
    // "your friend Alice signed up — you earned a free month".
    match /referralRedemptions/{redemptionId} {
      allow read: if isAuthed() && (
        resource.data.refereeUid == request.auth.uid
        || resource.data.referrerUid == request.auth.uid
        || isAdmin()
      );
      allow create, update, delete: if false;
    }

  }
}
