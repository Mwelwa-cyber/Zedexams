# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# IMPORTANT: browser-exposed Firebase vars must start with VITE_ for Vite.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps Static API key for embedding map images (school locations, exam
# centers, etc.). Enable the API at:
#   https://console.cloud.google.com/apis/library/static-maps-backend.googleapis.com
# Restrict the key to HTTP referrers (zedexams.com, *.web.app, localhost:5173)
# and to the Maps Static API only before shipping.
VITE_GOOGLE_MAPS_STATIC_KEY=AIzaSy...

# AI short-answer checking uses a Firebase Functions secret instead of
# browser .env values:
# npx -y firebase-tools@latest functions:secrets:set OPENAI_API_KEY

# Firebase AI Logic (client-side Gemini). Enable the API in the Firebase
# console under "Firebase AI Logic" and register the web app there. Protect
# the endpoint with App Check (reCAPTCHA Enterprise) in production — without
# it anyone with the public web config can run up your billing.
# Default model is gemini-2.5-flash; override here if needed.
# VITE_FIREBASE_AI_MODEL=gemini-2.5-flash

# Web push notifications (audit A5). The VAPID public key from
# Firebase Console → Project Settings → Cloud Messaging → Web Push
# certificates → Generate key pair. When set, learners with a 2+ day
# streak see an opt-in card on the dashboard; on grant their FCM token
# is saved to users/{uid}.fcmTokens for the daily-reminder Cloud
# Function (A5.2) to send to. When unset, the prompt never shows and
# no tokens are minted. Capacitor wrapper uses native push and ignores
# this var entirely.
# VITE_FIREBASE_VAPID_KEY=BPa...

# Sentry error monitoring (optional). When set, src/utils/sentry.js
# dynamically imports @sentry/react and starts capturing runtime
# errors + a 10% sample of perf traces + replays for sessions that
# hit an error. When unset, the SDK is tree-shaken out of the bundle.
# Get the DSN from Sentry → Settings → Projects → <your project> → Client Keys.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# VITE_APP_VERSION=1.1.0

# MTN MoMo payment secrets live in Firebase Functions too:
# npx -y firebase-tools@latest functions:secrets:set MTN_API_USER
# npx -y firebase-tools@latest functions:secrets:set MTN_API_KEY
# npx -y firebase-tools@latest functions:secrets:set MTN_SUBSCRIPTION_KEY
# npx -y firebase-tools@latest functions:secrets:set MTN_ENV
#
# MTN_ENV examples:
# - sandbox    (requests are sent in EUR by the MTN sandbox)
# - mtnzambia  (requests are sent in ZMW for Zambia live)

# Meta WhatsApp Business Cloud API delivery (audit A3 PR 3).
# Optional — the weeklyParentDigest cron soft-fails to email-only
# when these are unset, so the parent portal works whether or not
# you've finished WhatsApp onboarding with Meta.
#
# We swapped from Twilio to Meta direct because Twilio's trial-to-
# paid transition is bureaucratic and Meta's free tier (1000 service
# conversations/month) covers the digest's volume for years.
#
# Setup at a glance:
# 1. Create a Meta Business Account at business.facebook.com (free).
# 2. Go to developers.facebook.com → My Apps → Create App → "Other"
#    → "Business" → name it "ZedExams" or similar.
# 3. Add the WhatsApp product to the app (left rail → Add product
#    → WhatsApp → Set up).
# 4. The "Quickstart → API Setup" page gives you everything you need:
#    - "Temporary access token" (24h, free, perfect for first deploy)
#    - "Phone number ID" — a numeric ID under "From"
#    - "Test phone numbers" — add up to 5 recipient numbers that can
#       receive your test sends without business verification.
#       (This is the analogue of Twilio's sandbox — fine for proving
#        the wiring without going through full Meta Business
#        verification first.)
# 5. For production: Meta Business verification + register a
#    permanent System User access token + register a Message
#    Template (your weekly digest body) — that template's name goes
#    into META_WHATSAPP_TEMPLATE_NAME below.
#
# Set the secrets (these two are bound via defineSecret and required
# for the cron to send WhatsApp at all):
# npx -y firebase-tools@latest functions:secrets:set META_WHATSAPP_TOKEN
# npx -y firebase-tools@latest functions:secrets:set META_WHATSAPP_PHONE_NUMBER_ID
#
# Production only — optional, NOT a defineSecret. Add as a regular
# env var to functions/.env.examsprepzambia. The deploy will NOT
# fail if this is unset — test-phone sends use a free-form text body
# instead of a registered template:
#   META_WHATSAPP_TEMPLATE_NAME=zedexams_weekly_digest_v1
#
# Values:
#   META_WHATSAPP_TOKEN              Bearer token from Meta. Use the
#                                    Temporary token (24h, refreshable
#                                    for free) for first deploy. For
#                                    production, mint a System User
#                                    token under Business Settings →
#                                    Users → System Users → Generate
#                                    new token. Treat as a password.
#
#   META_WHATSAPP_PHONE_NUMBER_ID    The phone_number_id (NOT the
#                                    actual phone number) from the
#                                    API Setup page. Looks like
#                                    "123456789012345" — pure digits.
#
#   META_WHATSAPP_TEMPLATE_NAME      Optional. Name of an approved
#                                    Message Template. Variable
#                                    positions are fixed:
#                                      {{1}} learnerName
#                                      {{2}} summary line
#                                            ("3 quizzes, avg 78%")
#                                      {{3}} share URL.
#                                    Without this, sends use plain
#                                    text — fine for test-phone
#                                    verification, breaks once you
#                                    leave the 24h customer-initiated
#                                    window in production.
#
# Audit log: parentDigestEvents/{eventId} grows with one doc per send
# attempt. `channel` is "email" or "whatsapp"; `status` is "sent" /
# "failed" / "skipped". Meta-not-configured is silently skipped (no
# audit row) so the collection stays lean during pre-rollout.
