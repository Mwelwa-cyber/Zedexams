# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web App
# IMPORTANT: browser-exposed Firebase vars must start with VITE_ for Vite.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# AI short-answer checking and Zed assistant features use a Firebase Functions
# secret instead of browser .env values:
# npx -y firebase-tools@latest functions:secrets:set OPENAI_API_KEY

# MTN MoMo payment secrets live in Firebase Functions too:
# npx -y firebase-tools@latest functions:secrets:set MTN_API_USER
# npx -y firebase-tools@latest functions:secrets:set MTN_API_KEY
# npx -y firebase-tools@latest functions:secrets:set MTN_SUBSCRIPTION_KEY
# npx -y firebase-tools@latest functions:secrets:set MTN_ENV
#
# MTN_ENV examples:
# - sandbox    (requests are sent in EUR by the MTN sandbox)
# - mtnzambia  (requests are sent in ZMW for Zambia live)

# ── Zed Telegram assistant ────────────────────────────────────────
# Founder-only chat assistant. Setup steps live in
# functions/zedAssistant/SETUP.md.
#
# Secrets (set with `firebase functions:secrets:set ...`):
#   TELEGRAM_BOT_TOKEN        — from @BotFather → /newbot or /token
#   TELEGRAM_WEBHOOK_SECRET   — random string you generate, e.g.
#                               `openssl rand -hex 32`. Telegram echoes it
#                               back in every webhook request so the
#                               function can verify the call came from
#                               Telegram and not a random IP.
#
# Function env vars (set in functions/.env or via firebase functions:config):
#   ZED_TELEGRAM_ALLOWED_USERNAME=Mwelwam
#   ZED_TELEGRAM_ALLOWED_CHAT_ID=<your numeric chat id, set after first message>
# When the chat ID is set it overrides the username check (chat IDs are
# permanent; usernames can change).
