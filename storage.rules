rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthed() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function isTeacherOrAdmin() {
      return isAuthed()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && (userDoc().data.role == 'teacher' || userDoc().data.role == 'admin');
    }

    function isAdmin() {
      return isAuthed()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc().data.role == 'admin';
    }

    function ownsPath(ownerUid) {
      return isAuthed() && request.auth.uid == ownerUid;
    }

    function validPaperUpload() {
      return request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    function validQuizImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    function validLessonImageUpload() {
      return request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp|gif)');
    }

    function validLessonPresentationUpload() {
      // SVG is intentionally excluded — pptxPresentationRenderer.js used to
      // upload programmatically-built SVG slides, but a malicious .pptx could
      // inject script-bearing attributes that would execute on direct-URL
      // navigation against firebasestorage.googleapis.com. The renderer now
      // rasterizes to PNG via canvas before upload.
      return request.resource.size <= 50 * 1024 * 1024
        && (
          request.resource.contentType == 'application/vnd.openxmlformats-officedocument.presentationml.presentation'
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('image/(jpeg|png|webp)')
        );
    }

    function validLessonFileUpload() {
      return request.resource.size <= 25 * 1024 * 1024
        && (
          request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/msword'
          || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
        );
    }

    // Past papers: learners can read, teachers/admins can only write under
    // their own user folder. One-level legacy writes are admin-only.
    match /papers/{ownerUid}/{fileName=**} {
      allow read: if isAuthed();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validPaperUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    match /papers/{fileName} {
      allow read: if isAuthed();
      allow create, update: if isAdmin() && validPaperUpload();
      allow delete: if isAdmin();
    }

    // Quiz question images: teachers/admins can upload only to their own folder.
    match /quiz-images/{ownerUid}/{fileName=**} {
      allow read: if isAuthed();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validQuizImageUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    // Teacher-private assessment question images. Only the owning teacher
    // and admins can read these (assessments are not learner-facing).
    match /assessment-images/{ownerUid}/{fileName=**} {
      allow read: if ownsPath(ownerUid) || isAdmin();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validQuizImageUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    // Imported lesson images: teachers/admins upload into their own folder.
    // Learners can read them as part of playable lessons.
    match /lesson-images/{ownerUid}/{assetBatchId}/{fileName=**} {
      allow read: if isAuthed();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validLessonImageUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    // Preserved PowerPoint lessons: original PPTX plus generated web slides.
    match /lesson-presentations/{ownerUid}/{assetBatchId}/{fileName=**} {
      allow read: if isAuthed();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validLessonPresentationUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    // CDC syllabi library: world-readable static PDFs (free for all teachers).
    // The viewer iframe loads these via tokenless `?alt=media` URLs so they
    // must be public. Writes are admin-only and gated by validPaperUpload.
    match /syllabi/{fileName=**} {
      allow read: if true;
      allow create, update: if isAdmin() && validPaperUpload();
      allow delete: if isAdmin();
    }

    // Syllabus-replacement Phase A: admin uploads new .xlsx syllabi here
    // and the parseSyllabusUpload Cloud Function (Storage onFinalize)
    // extracts them into cbcKnowledgeBase/{version}/draftTopics. Reads
    // are admin-only too — drafts may include unpublished curriculum.
    function validSyllabusXlsxUpload() {
      return request.resource.size < 25 * 1024 * 1024
        && (
          request.resource.contentType ==
            'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
          || request.resource.contentType == 'application/octet-stream'
        );
    }
    match /syllabus-uploads/{version}/{fileName=**} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && validSyllabusXlsxUpload();
      allow delete: if isAdmin();
    }

    // PDF syllabi uploaded by admins for the extractTopicsFromPdf callable
    // (functions/teacherTools/extractTopicsFromPdf.js). PDF-only; the
    // callable rejects any path that doesn't end in .pdf, but the rule
    // pins it on the storage side too so non-PDF uploads can't squat the
    // path and bypass the callable's quota meter.
    function validSyllabusPdfUpload() {
      return request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }
    match /syllabus-uploads-pdf/{version}/{fileName=**} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && validSyllabusPdfUpload();
      allow delete: if isAdmin();
    }

    // Notes Studio inline images: PNG/JPEG/WebP/GIF up to 5 MB, written by
    // the rich-text editor. Must come BEFORE the whole-note files match
    // since {fileName=**} would otherwise swallow the /inline/ segment.
    match /lesson-files/{ownerUid}/{assetBatchId}/inline/{fileName=**} {
      allow read: if isAuthed();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validLessonImageUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    // Notes Studio whole-note files: PDF or Word (DOC/DOCX), 25 MB max.
    // Mirrors lesson-images / lesson-presentations: keyed by assetBatchId
    // because lessons may not have a Firestore doc id at upload time.
    match /lesson-files/{ownerUid}/{assetBatchId}/{fileName=**} {
      allow read: if isAuthed();
      allow create, update: if ownsPath(ownerUid)
        && isTeacherOrAdmin()
        && validLessonFileUpload();
      allow delete: if ownsPath(ownerUid) && isTeacherOrAdmin();
    }

    // Audit D3 — MoMo invoice PDFs. Writes are admin-only (the
    // invoiceGenerator Cloud Function uses the admin SDK so this
    // doesn't block legitimate generation). Reads are owner +
    // admin; the path's own segment carries the userId so a
    // tampered client can't enumerate someone else's receipts.
    match /invoices/{userId}/{fileName} {
      allow read: if isAuthed() && (request.auth.uid == userId || isAdmin());
      allow write: if false;
    }

    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
