rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Past papers — any authenticated user can read
    match /papers/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024   // 20 MB max
        && (request.resource.contentType == 'application/pdf'
            || request.resource.contentType.matches('image/.*'));
    }
    // Quiz question images — authenticated users can read; only admins write
    // (Storage can't query Firestore roles, so we enforce size + type here)
    match /quiz-images/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024   // 5 MB max
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    // Block all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
