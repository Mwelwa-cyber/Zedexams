{
  "permissions": {
    "allow": [
      "Bash(npx vite:*)",
      "Bash(node -e ':*)",
      "Bash(git push:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)"
